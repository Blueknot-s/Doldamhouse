{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "*.tsx",
    "*.ts",
    "components/**/*.tsx",
    "components/**/*.ts",
    "pages/**/*.tsx",
    "pages/**/*.ts",
    "constants.ts",
    "types.ts",
    "firebase.ts",
    "react-quill.d.ts"
  ],
  "exclude": [
    "node_modules",
    "src",
    "api",
    "dist"
  ]
}